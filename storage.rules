rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Regra geral: Apenas usuários autenticados podem interagir com o Storage.
    function isSignedIn() {
      return request.auth != null;
    }

    // Pasta de imagens de perfil
    match /profile_images/{userId}/{fileName} {

      // Permite leitura de qualquer imagem de perfil, pois elas são públicas.
      allow read;

      // Permite escrita (upload, atualização, exclusão) apenas se o usuário
      // autenticado for o dono do perfil (o `userId` da pasta).
      allow write: if isSignedIn() && request.auth.uid == userId;

      // Validações adicionais para o upload:
      // - Garante que o arquivo seja uma imagem (jpeg, png, jpg).
      // - Garante que o tamanho do arquivo seja no máximo 5MB.
      allow create: if isSignedIn() && 
                      request.auth.uid == userId &&
                      request.resource.size < 5 * 1024 * 1024 &&
                      request.resource.contentType.matches('image/(jpeg|png|jpg)');
    }
  }
}
